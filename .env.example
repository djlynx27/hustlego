# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_VAPID_PUBLIC_KEY=      # clé publique Web Push VAPID (frontend)

# Variables backend Edge Functions (à définir via `supabase secrets set`)
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:alerts@hustlego.local

# ── Cartographie / Trafic ─────────────────────────────────────────────────────
VITE_MAPBOX_TOKEN=          # maps.mapbox.com → Tokens
VITE_TOMTOM_KEY=            # developer.tomtom.com → My Apps

# ── Données temps réel ────────────────────────────────────────────────────────
# STM (Société de transport de Montréal) — GRATUIT
# Inscription : portail.developpeurs.stm.info
# Permet : GTFS-RT serviceAlerts, vehiclePositions, tripUpdates
VITE_STM_KEY=

# AviationStack — optionnel, 100 req/mois GRATUIT
# Inscription : aviationstack.com (plan Free)
# Utilisé pour enrichir les vagues d'arrivées YUL avec des données live
# Fallback : schedule statique intégré si absent
VITE_AVIATIONSTACK_KEY=

# ── Événements ────────────────────────────────────────────────────────────────
# Ticketmaster Discovery API — GRATUIT
# Inscription : developer.ticketmaster.com
VITE_TICKETMASTER_KEY=

# ── Lieux (optionnel) ─────────────────────────────────────────────────────────
VITE_FOURSQUARE_API_KEY=
